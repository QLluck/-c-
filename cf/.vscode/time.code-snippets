{
  "通用时间标注模板": {
    "scope": "cpp,plaintext,markdown", // 可生效的文件类型（按需增减）
    "prefix": "time",                  // 触发词：输入time+Tab触发
    "body": [
      "/* 当前时间：${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND} */",
      "$0" // 光标最终定位到模板下方，无黑框
    ],
    "description": "显示当前年月日时分秒的时间模板"
  }
}